# S3 / Cloudflare R2
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=data-ingestion
S3_REGION=auto

# Firecrawl (fallback scraper — optional)
FIRECRAWL_API_KEY=

# Search APIs
EXA_API_KEY=                          # optional fallback
TAVILY_API_KEY=                        # https://tavily.com
PARALLEL_API_KEY=                      # https://platform.parallel.ai

# Parallel Monitor IDs (run `npx tsx setup-monitors.ts` once to generate)
PARALLEL_MONITOR_RESEARCH_ID=
PARALLEL_MONITOR_STARTUP_ID=

# LLM Providers
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=

# Reddit API (for fetching post details)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Email Delivery (Resend - https://resend.com)
RESEND_API_KEY=
NEWSLETTER_RECIPIENTS=

# Ghost CMS
GHOST_ADMIN_API_KEY=
GHOST_CONTENT_API_KEY=
GHOST_API_URL=https://your-ghost-site.com
