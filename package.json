{
  "name": "salish",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "ingest": "NODE_ENV=development tsx src/cli.ts ingest",
    "generate": "NODE_ENV=development tsx src/cli.ts generate",
    "ghost": "NODE_ENV=development tsx src/cli.ts ghost",
    "email": "NODE_ENV=development tsx src/cli.ts email",
    "send": "NODE_ENV=development tsx src/cli.ts send",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:dev": "wrangler dev src/worker/index.ts",
    "worker:deploy:dev": "wrangler deploy src/worker/index.ts --env dev",
    "worker:deploy:prod": "wrangler deploy src/worker/index.ts --env production",
    "worker:setup": "./wrangler-setup.sh",
    "worker:tail": "wrangler tail --env dev",
    "worker:trigger": "curl -X POST http://localhost:8787/trigger",
    "worker:test": "tsx src/worker/test-manual.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@aws-sdk/client-s3": "^3.988.0",
    "@mistralai/mistralai": "^1.14.0",
    "dotenv": "^17.2.4",
    "resend": "^6.9.2",
    "rss-parser": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260219.0",
    "@types/node": "^25.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.67.0"
  }
}
